{
  "name": "spiral",
  "version": "4.0.9",
  "description": "Spiral - 軽くて速いブラウザ",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dev": "electron . --inspect"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.spiral.browser",
    "productName": "Spiral",
    "publish": [
      {
        "provider": "github",
        "owner": "Arceus-S5",
        "repo": "spiral"
      }
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "author": "Arceus-S5",
  "license": "MIT"
}
